# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
next_dev.log

# production
/build
/dist

# misc
.DS_Store
*.pem
*.log
logs/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (NEVER commit sensitive data)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# vercel
.vercel

# IDEs
.idea/
.vscode/

# backend safety
backend/node_modules/
backend/uploads/
backend/logs/

# typescript
*.tsbuildinfo
next-env.d.ts
